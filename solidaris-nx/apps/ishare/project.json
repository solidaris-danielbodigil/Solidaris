{
  "name": "iSHARE",
  "root": "apps/ishare",
  "sourceRoot": "apps/ishare/src",
  "projectType": "application",
  "architect": {
    "build": {
      "builder": "@nrwl/angular:browser",
      "options": {
        "outputPath": "dist/apps/ishare",
        "index": "apps/ishare/src/index.html",
        "main": "apps/ishare/src/main.ts",
        "polyfills": "apps/ishare/src/polyfills.ts",
        "tsConfig": "apps/ishare/tsconfig.app.json",
        "assets": [
          "apps/ishare/src/favicon.ico",
          "apps/ishare/src/assets"
        ],
        "styles": [
          "libs/styles/src/main.scss"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/ishare/src/environments/environment.ts",
              "with": "apps/ishare/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "extractCss": true,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "vendorChunk": false,
          "buildOptimizer": true
        }
      }
    },
    "serve": {
      "builder": "@nrwl/angular:dev-server",
      "options": {
        "browserTarget": "iSHARE:build"
      },
      "configurations": {
        "production": {
          "browserTarget": "iSHARE:build:production"
        }
      }
    },
    "test": {
      "builder": "@nrwl/jest:jest",
      "options": {
        "jestConfig": "apps/ishare/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "builder": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "apps/ishare/**/*.ts",
          "apps/ishare/**/*.html",
          "apps/ishare/**/*.scss"
        ]
      }
    }
  }
}